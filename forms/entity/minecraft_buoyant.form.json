{
  "$schema": "../../../schemas/dataform/form-definition.schema.json",
  "summarizer": {
    "phrases": [
      {
        "tokens": [
          {
            "type": "literal",
            "text": "floats on liquid surfaces"
          }
        ]
      }
    ]
  },
  "fields": [
    {
      "id": "apply_gravity",
      "title": "Apply Gravity",
      "description": "Applies gravity each tick. Causes \"movement_type\" to be more impactful, but also gravity to be applied more intensely outside liquids.",
      "defaultValue": true,
      "dataType": "boolean"
    },
    {
      "id": "base_buoyancy",
      "title": "Base Buoyancy",
      "description": "Base buoyancy used to calculate how much will a entity float.",
      "defaultValue": 1,
      "dataType": "float",
      "samples": {
        "/vanilla/behavior_pack/entities/sulfur_cube.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:sulfur_cube_bouncy/minecraft:buoyant/",
            "content": 1
          },
          {
            "path": "/minecraft:entity/component_groups/minecraft:sulfur_cube_regular/minecraft:buoyant/",
            "content": 1
          }
        ]
      }
    },
    {
      "id": "big_wave_probability",
      "title": "Big Wave Probability",
      "description": "Probability for a big wave hitting the entity. Only used if \"movement_type\" is \"waves\".",
      "defaultValue": 0.03,
      "dataType": "float"
    },
    {
      "id": "big_wave_speed",
      "title": "Big Wave Speed",
      "description": "Multiplier for the speed to make a big wave. Triggered depending on \"big_wave_probability\".",
      "defaultValue": 10,
      "dataType": "float"
    },
    {
      "id": "can_auto_step_from_liquid",
      "title": "Can Auto Step From Liquid",
      "description": "Whether the entity can move out of a liquid block to a neighboring solid block if pushed against it.",
      "defaultValue": false,
      "dataType": "boolean",
      "samples": {
        "/vanilla/behavior_pack/entities/sulfur_cube.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:sulfur_cube_bouncy/minecraft:buoyant/",
            "content": true
          },
          {
            "path": "/minecraft:entity/component_groups/minecraft:sulfur_cube_regular/minecraft:buoyant/",
            "content": true
          }
        ]
      }
    },
    {
      "id": "drag_down_on_buoyancy_removed",
      "title": "Drag Down On Buoyancy Removed",
      "description": "How much an entity will be dragged down when the component is removed.",
      "defaultValue": 0,
      "dataType": "float"
    },
    {
      "id": "liquid_blocks",
      "title": "Liquid Blocks",
      "description": "List of blocks this entity can float on. Must be a liquid block.",
      "dataType": "stringArray",
      "samples": {
        "/vanilla/behavior_pack/entities/sulfur_cube.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:sulfur_cube_bouncy/minecraft:buoyant/",
            "content": [
              "minecraft:water",
              "minecraft:flowing_water",
              "minecraft:lava",
              "minecraft:flowing_lava"
            ]
          },
          {
            "path": "/minecraft:entity/component_groups/minecraft:sulfur_cube_regular/minecraft:buoyant/",
            "content": [
              "minecraft:water",
              "minecraft:flowing_water",
              "minecraft:lava",
              "minecraft:flowing_lava"
            ]
          }
        ],
        "/vanilla/behavior_pack/entities/xp_orb.json": [
          {
            "path": "/minecraft:entity/components/minecraft:buoyant/",
            "content": [
              "minecraft:flowing_water",
              "minecraft:water"
            ]
          }
        ]
      }
    },
    {
      "id": "movement_type",
      "title": "Movement Type",
      "description": "Type of vertical movement applied to the entity:\n\"waves\", simulates wave movement based on the entity speed.\n\"bobbing\", simulates waves going through.\n\"none\", simulates waves going through.",
      "defaultValue": "waves",
      "dataType": "string",
      "samples": {
        "/vanilla/behavior_pack/entities/sulfur_cube.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:sulfur_cube_bouncy/minecraft:buoyant/",
            "content": "bobbing"
          },
          {
            "path": "/minecraft:entity/component_groups/minecraft:sulfur_cube_regular/minecraft:buoyant/",
            "content": "bobbing"
          }
        ]
      }
    }
  ],
  "description": "Enables an entity to float on the specified liquid blocks.",
  "title": "Buoyant",
  "samples": {
    "/vanilla/behavior_pack/entities/sulfur_cube.json": [
      {
        "path": "/minecraft:entity/component_groups/minecraft:sulfur_cube_bouncy/minecraft:buoyant/",
        "content": {
          "base_buoyancy": 1,
          "apply_gravity": false,
          "can_auto_step_from_liquid": true,
          "movement_type": "bobbing",
          "liquid_blocks": [
            "minecraft:water",
            "minecraft:flowing_water",
            "minecraft:lava",
            "minecraft:flowing_lava"
          ]
        }
      },
      {
        "path": "/minecraft:entity/component_groups/minecraft:sulfur_cube_regular/minecraft:buoyant/",
        "content": {
          "base_buoyancy": 1,
          "apply_gravity": false,
          "can_auto_step_from_liquid": true,
          "movement_type": "bobbing",
          "liquid_blocks": [
            "minecraft:water",
            "minecraft:flowing_water",
            "minecraft:lava",
            "minecraft:flowing_lava"
          ]
        }
      },
      {
        "path": "/minecraft:entity/component_groups/minecraft:sulfur_cube_light/minecraft:buoyant/",
        "content": {
          "base_buoyancy": 1,
          "apply_gravity": false,
          "can_auto_step_from_liquid": true,
          "movement_type": "bobbing",
          "liquid_blocks": [
            "minecraft:water",
            "minecraft:flowing_water",
            "minecraft:lava",
            "minecraft:flowing_lava"
          ]
        }
      }
    ],
    "/vanilla/behavior_pack/entities/xp_orb.json": [
      {
        "path": "/minecraft:entity/components/minecraft:buoyant/",
        "content": {
          "apply_gravity": false,
          "liquid_blocks": [
            "minecraft:flowing_water",
            "minecraft:water"
          ]
        }
      }
    ]
  },
  "id": "minecraft:buoyant"
}