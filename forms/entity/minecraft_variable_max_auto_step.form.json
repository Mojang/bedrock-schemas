      "dataType": "float",
      "samples": {
        "/vanilla/behavior_pack/entities/sulfur_cube.json": [
          {
            "path": "/minecraft:entity/component_groups/minecraft:sulfur_cube_ai/minecraft:variable_max_auto_step/",
            "content": 0.5625
          }
        ]
      }
    },
    {
      "id": "jump_prevented_value",
      "title": "Jump Prevented Value",
      "description": "The maximum auto step height when on a block that prevents jumping.",
      "defaultValue": 0.5625,
      "dataType": "float",
